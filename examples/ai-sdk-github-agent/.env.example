# A GitHub App (or an OAuth app with "Expire user authorization tokens" enabled)
# so the token endpoint returns a ROTATING refresh token — that's the case this
# example exists to handle. Seed the initial refresh token below; nominee rotates
# and persists it from then on (into ./.tokens.json via onRefreshToken).
GITHUB_CLIENT_ID=Iv1_xxx
GITHUB_CLIENT_SECRET=xxx
GITHUB_REFRESH_TOKEN=ghr_xxx

# Any OpenAI-compatible gateway. This example uses OpenRouter.
OPENROUTER_API_KEY=sk-or-xxx
